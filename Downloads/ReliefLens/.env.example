# Google AI Studio (Gemma 4)
VITE_GOOGLE_AI_API_KEY=

# MongoDB Atlas (RAG Vector Search)
VITE_MONGODB_URI=
VITE_MONGODB_DB=relieflens
VITE_MONGODB_COLLECTION=knowledge_base

# App Config
VITE_APP_NAME=ReliefLens
VITE_AUTO_DELETE_DAYS=30
VITE_CONFIDENCE_REVIEW_THRESHOLD=0.65

# Gemma Model (gemma-2.0-flash-exp or gemma-4-vision-preview)
VITE_GEMMA_MODEL=gemma-2.0-flash-exp
VITE_GEMMA_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# ARIA Voice Config
VITE_ARIA_VOICE_NAME=Aoede

# Backend API (optional — Vite proxies /api to localhost:3001 in dev)
VITE_API_BASE_URL=

# Server-only (copy to .env.local — used by npm run server)
MONGODB_URI=
GOOGLE_AI_API_KEY=
GEMMA_MODEL=gemma-4-31b-it
TTS_MODEL=gemini-2.5-flash-preview-tts
GMAIL_USER=your-account@gmail.com
GMAIL_APP_PASSWORD=
# Alias also supported:
# GOOGLE_APP_PASSWORD=
PORT=3001
